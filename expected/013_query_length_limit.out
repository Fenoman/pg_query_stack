-- Тест 013: Полный текст запроса без усечения
-- Проверяет что pg_query_stack возвращает полный sourceText без усечения.
-- Это важно для аудита длинных DDL-запросов и больших миграций.
-- Запрос намеренно содержит очень длинную строку — проверяем что она не обрезается.
WITH CTE AS (
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                UNION ALL
                SELECT
                    ''
                LIMIT 1
            )
SELECT
    CASE
        WHEN LENGTH(query_text) > 524288
            THEN 'OK_full_source'
        ELSE 'ERR_unexpected_length'
    END AS status
FROM pg_query_stack(0) AS T, CTE;
     status     
----------------
 OK_full_source
(1 row)

-- Проверяем что обычные запросы не обрезаются
SELECT
    LENGTH('_long_query') AS normal_query_length,
    CASE
        WHEN query_text LIKE '%test_long_query%'
            THEN 'OK_full'
        ELSE 'ERR_truncated'
    END AS normal_query_status
FROM pg_query_stack(0)
WHERE frame_number = 0;
 normal_query_length | normal_query_status 
---------------------+---------------------
                 313 | OK_full
(1 row)

DISCARD ALL;
