-- Тест 016: swallowed exception внутри вложенного AFTER trigger
-- Ошибка в nested trigger проглатывается EXCEPTION-блоком, но стек должен
-- очиститься после отката внутренней подтранзакции.
DROP TABLE IF EXISTS test_src CASCADE;
NOTICE:  table "test_src" does not exist, skipping
DROP TABLE IF EXISTS test_queue CASCADE;
NOTICE:  table "test_queue" does not exist, skipping
CREATE TABLE test_src
(
    id     integer PRIMARY KEY,
    c_text text
);
CREATE TABLE test_queue
(
    id      integer GENERATED BY DEFAULT AS IDENTITY,
    payload text,
    c_error text
);
CREATE OR REPLACE FUNCTION public.test_queue_after_insert () RETURNS trigger
    LANGUAGE plpgsql
AS
$$
DECLARE
    _c_error text;
BEGIN
    BEGIN
        PERFORM 1 / 0;
    EXCEPTION
        WHEN OTHERS THEN _c_error = SQLERRM;
    END;

    UPDATE test_queue q
    SET
        c_error = _c_error
    FROM inserted i
    WHERE q.id = i.id;

    RETURN NULL;
END;
$$;
CREATE TRIGGER test_queue_after_insert
    AFTER INSERT
    ON test_queue
    REFERENCING NEW TABLE AS inserted
    FOR EACH STATEMENT
EXECUTE PROCEDURE public.test_queue_after_insert();
CREATE OR REPLACE FUNCTION public.test_src_after_update () RETURNS trigger
    LANGUAGE plpgsql
AS
$$
BEGIN
    INSERT INTO test_queue
    (
        payload
    )
    SELECT
        i.c_text
    FROM inserted i;

    RETURN NULL;
END;
$$;
CREATE TRIGGER test_src_after_update
    AFTER UPDATE
    ON test_src
    REFERENCING NEW TABLE AS inserted OLD TABLE AS deleted
    FOR EACH STATEMENT
EXECUTE PROCEDURE public.test_src_after_update();
INSERT INTO test_src
(
    id,
    c_text
)
VALUES
    (1, 'old');
UPDATE test_src
SET
    c_text = 'new'
WHERE id = 1;
SELECT
    frame_number,
    query_text
FROM public.pg_query_stack(0);
 frame_number |           query_text           
--------------+--------------------------------
            0 | SELECT                        +
              |     frame_number,             +
              |     query_text                +
              | FROM public.pg_query_stack(0);
(1 row)

DROP TABLE test_src CASCADE;
DROP TABLE test_queue CASCADE;
